# Choose one credential source:
LINEAR_API_KEY=lin_api_...
# LINEAR_ACCESS_TOKEN=...

# Optional defaults:
# LINEAR_TEAM=ENG

# OAuth (optional, for `linear-axi auth login`):
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_REDIRECT_URI=http://127.0.0.1:14582/oauth/callback
# LINEAR_OAUTH_SCOPE=read,write
# LINEAR_OAUTH_ACTOR=user
