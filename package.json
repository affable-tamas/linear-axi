{
  "name": "linear-axi",
  "version": "0.1.0",
  "description": "AXI-compliant Linear CLI — token-efficient TOON output, contextual suggestions, dry-run mutations",
  "license": "MIT",
  "type": "module",
  "bin": {
    "linear-axi": "./dist/bin/linear-axi.js"
  },
  "files": [
    "dist",
    "skills/linear-axi",
    ".env.example",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/affable-tamas/linear-axi.git"
  },
  "keywords": [
    "linear",
    "axi",
    "cli",
    "agent",
    "toon"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "build:skill": "tsx scripts/build-skill.ts",
    "check": "npm run build && npm test && npm run build:skill -- --check",
    "dev": "tsx bin/linear-axi.ts",
    "prepublishOnly": "npm run build && npm run build:skill",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@linear/sdk": "^88.0.0",
    "@toon-format/toon": "^2.3.0",
    "axi-sdk-js": "^0.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
